{
  "$comment": "Build the second repair. Success logs the edit; failure aborts (two repairs exhausted).",
  "id": "edit_file.rebuild2",
  "kind": "action",
  "tool": "stage_and_build",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "edit_file.fix2", "path": ".", "as": "code" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "code": "{{ code }}" },
  "on_success": "edit_file.log",
  "on_failure": "edit_file.fail"
}
