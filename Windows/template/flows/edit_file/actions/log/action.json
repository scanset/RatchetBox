{
  "$comment": "Record the edit in the project's on-disk memory (PROJECT.md changelog). Non-fatal: even if logging fails, the edit already built, so go to done.",
  "id": "edit_file.log",
  "kind": "action",
  "tool": "log_edit",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "summary" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "summary": "{{ summary }}" },
  "on_success": "edit_file.done",
  "on_failure": "edit_file.done"
}
