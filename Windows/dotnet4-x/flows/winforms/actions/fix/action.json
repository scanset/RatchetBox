{
  "id": "winforms.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "$input", "path": ".", "as": "task" },
    { "from": "winforms.generate", "path": ".", "as": "prev", "max_chars": 5000 },
    { "from": "winforms.compile", "path": ".", "as": "errors", "max_chars": 2000 }
  ],
  "on_success": "winforms.recompile",
  "on_failure": "winforms.fail"
}
