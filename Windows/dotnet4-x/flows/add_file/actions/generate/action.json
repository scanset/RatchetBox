{
  "id": "add_file.generate",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "request" },
    { "search": "kb", "query": "{{ request }}", "k": 2, "as": "refs", "max_chars": 1500 }
  ],
  "on_success": "add_file.build",
  "on_failure": "add_file.fail"
}
