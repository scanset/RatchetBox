{
  "id": "create_spec.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "request", "path": ".", "as": "request" },
    { "from": "create_spec.generate", "path": ".", "as": "prev", "max_chars": 4000 },
    { "from": "create_spec.validate", "path": ".", "as": "errors", "max_chars": 2000 }
  ],
  "on_success": "create_spec.revalidate",
  "on_failure": "create_spec.fail"
}
