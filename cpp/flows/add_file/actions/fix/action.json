{
  "id": "add_file.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "request" },
    { "from": "add_file.generate", "path": ".", "as": "prev", "max_chars": 6000 },
    { "from": "add_file.build", "path": ".", "as": "errors", "max_chars": 2000 },
    { "search": "errors", "query": "{{ errors }}", "k": 2, "as": "errhelp", "max_chars": 1500 }
  ],
  "on_success": "add_file.rebuild",
  "on_failure": "add_file.fail"
}
