{
  "id": "add_unit.rebuild2",
  "kind": "action",
  "tool": "stage_unit",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "add_unit.fix2", "path": ".", "as": "code" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "code": "{{ code }}" },
  "on_success": "add_unit.register",
  "on_failure": "add_unit.fail"
}
