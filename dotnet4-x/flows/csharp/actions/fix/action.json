{
  "$comment": "The repair: regenerate the C# given the compiler errors + the previous attempt. Bounded - one fix, then recompile.",
  "id": "csharp.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "$input", "path": ".", "as": "task" },
    { "from": "csharp.generate", "path": ".", "as": "prev", "max_chars": 4000 },
    { "from": "csharp.compile", "path": ".", "as": "errors", "max_chars": 2000 }
  ],
  "on_success": "csharp.recompile",
  "on_failure": "csharp.fail"
}
