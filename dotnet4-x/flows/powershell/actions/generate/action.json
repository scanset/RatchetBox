{
  "id": "powershell.generate",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "$input", "path": ".", "as": "task" },
    { "search": "kb", "query": "{{ task }}", "k": 2, "as": "refs", "max_chars": 2000 }
  ],
  "on_success": "powershell.parse",
  "on_failure": "powershell.fail"
}
