{
  "id": "powershell.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "$input", "path": ".", "as": "task" },
    { "from": "powershell.generate", "path": ".", "as": "prev", "max_chars": 4000 },
    { "from": "powershell.parse", "path": ".", "as": "errors", "max_chars": 2000 }
  ],
  "on_success": "powershell.reparse",
  "on_failure": "powershell.fail"
}
