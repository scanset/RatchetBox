{
  "id": "winforms.generate",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "$input", "path": ".", "as": "task" },
    { "search": "kb", "query": "winforms {{ task }}", "k": 2, "as": "refs", "max_chars": 2000 }
  ],
  "on_success": "winforms.compile",
  "on_failure": "winforms.fail"
}
