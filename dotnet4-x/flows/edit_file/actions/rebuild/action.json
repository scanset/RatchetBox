{
  "id": "edit_file.rebuild",
  "kind": "action",
  "tool": "stage_and_build",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "edit_file.fix", "path": ".", "as": "code" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "code": "{{ code }}" },
  "on_success": "edit_file.log",
  "on_failure": "edit_file.fix2"
}
