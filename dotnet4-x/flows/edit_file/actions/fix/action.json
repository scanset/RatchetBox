{
  "id": "edit_file.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "request" },
    { "from": "edit_file.generate", "path": ".", "as": "prev", "max_chars": 6000 },
    { "from": "edit_file.build", "path": ".", "as": "errors", "max_chars": 2000 }
  ],
  "on_success": "edit_file.rebuild",
  "on_failure": "edit_file.fail"
}
