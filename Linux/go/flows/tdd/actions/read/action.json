{
  "$comment": "Read every .spec in the workspace for the test-first build.",
  "id": "tdd.read", "kind": "action", "tool": "read_specs",
  "inputs": [ { "from": "$workspace", "path": ".", "as": "ws" } ],
  "body": { "dir": "{{ ws }}/specs" },
  "on_success": "tdd.stub", "on_failure": "tdd.fail"
}
