{
  "$comment": "Generate ONE Go unit, grounded on its spec, the existing module API (with import paths), the module state, and KB hits (stdlib, patterns, pitfalls, guidelines, deps) keyed on the spec. The unit's package is derived from {{ path }}: root -> package main; <dir>/x.go -> package <dir>.",
  "id": "add_unit.generate",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    {
      "from": "add_unit.readspec",
      "path": ".",
      "as": "spec"
    },
    {
      "from": "add_unit.api",
      "path": ".",
      "as": "api"
    },
    {
      "from": "add_unit.readproj",
      "path": ".",
      "as": "project",
      "max_chars": 5000
    },
    {
      "from": "path",
      "path": ".",
      "as": "path"
    },
    {
      "search": "stdlib",
      "query": "{{ spec }}",
      "k": 1,
      "as": "stdlib_refs",
      "max_chars": 2500
    },
    {
      "search": "patterns",
      "query": "{{ spec }}",
      "k": 1,
      "as": "pattern_refs",
      "max_chars": 2500
    },
    {
      "search": "pitfalls",
      "query": "{{ spec }}",
      "k": 1,
      "as": "pitfall_refs",
      "max_chars": 2000
    },
    {
      "search": "guidelines",
      "query": "{{ spec }}",
      "k": 1,
      "as": "guideline_refs",
      "max_chars": 2000
    },
    {
      "search": "recipes",
      "query": "{{ spec }}",
      "k": 1,
      "as": "recipe_refs",
      "max_chars": 2500
    },
    {
      "search": "deps",
      "query": "{{ spec }}",
      "k": 1,
      "as": "dep_refs",
      "max_chars": 2500
    },
    {
      "search": "concurrency",
      "query": "{{ spec }}",
      "k": 1,
      "as": "concurrency_refs",
      "max_chars": 2500
    },
    {
      "search": "cache",
      "query": "{{ spec }}",
      "k": 1,
      "as": "cache_refs",
      "max_chars": 2500
    }
  ],
  "on_success": "add_unit.build",
  "on_failure": "add_unit.fail"
}