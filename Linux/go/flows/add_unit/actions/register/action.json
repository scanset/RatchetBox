{
  "$comment": "Record the unit in the module's PROJECT.md. Best-effort: register_file always exits 0, so this never fails the unit (it already built).",
  "id": "add_unit.register",
  "kind": "action",
  "tool": "register_file",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "role": "composed unit" },
  "on_success": "add_unit.done",
  "on_failure": "add_unit.done"
}
