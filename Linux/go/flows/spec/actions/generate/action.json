{
  "$comment": "Draft the spec(s) grounded on the SELECTED KBs (catalog-driven dynamic retrieval): extract the top-3 verified selections and search each at runtime (search target = the chosen KB, resolved from a slot), replacing the old 6 fixed search blocks. Output is marker-separated .spec blocks the write_specs oracle validates + writes.",
  "id": "spec.generate",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "$input", "path": ".", "as": "desc" },
    { "from": "spec.plan", "path": "selections/0/kb", "as": "kb1" },
    { "from": "spec.plan", "path": "selections/0/query", "as": "q1" },
    { "from": "spec.plan", "path": "selections/1/kb", "as": "kb2" },
    { "from": "spec.plan", "path": "selections/1/query", "as": "q2" },
    { "from": "spec.plan", "path": "selections/2/kb", "as": "kb3" },
    { "from": "spec.plan", "path": "selections/2/query", "as": "q3" },
    { "search": "{{ kb1 }}", "query": "{{ q1 }}", "k": 2, "as": "refs1", "max_chars": 3000 },
    { "search": "{{ kb2 }}", "query": "{{ q2 }}", "k": 2, "as": "refs2", "max_chars": 3000 },
    { "search": "{{ kb3 }}", "query": "{{ q3 }}", "k": 1, "as": "refs3", "max_chars": 2000 }
  ],
  "on_success": "spec.write",
  "on_failure": "spec.fail"
}
