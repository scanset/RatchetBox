{
  "$comment": "Record the new file in the project's on-disk memory (project.json.files + PROJECT.md). Non-fatal: it already built, so go to done either way.",
  "id": "add_file.register",
  "kind": "action",
  "tool": "register_file",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "role": "added via add_file chain" },
  "on_success": "add_file.done",
  "on_failure": "add_file.done"
}
