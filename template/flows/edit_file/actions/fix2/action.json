{
  "$comment": "Second repair attempt: the first rebuild still failed. Regenerate from the fix's output and the rebuild's errors. Last chance before fail.",
  "id": "edit_file.fix2",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "request" },
    { "from": "edit_file.fix", "path": ".", "as": "prev", "max_chars": 6000 },
    { "from": "edit_file.rebuild", "path": ".", "as": "errors", "max_chars": 2000 }
  ],
  "on_success": "edit_file.rebuild2",
  "on_failure": "edit_file.fail"
}
