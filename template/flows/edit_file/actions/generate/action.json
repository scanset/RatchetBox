{
  "id": "edit_file.generate",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "request" },
    { "from": "edit_file.read", "path": ".", "as": "current", "max_chars": 6000 },
    { "search": "kb", "query": "{{ request }}", "k": 2, "as": "refs", "max_chars": 1500 }
  ],
  "on_success": "edit_file.build",
  "on_failure": "edit_file.fail"
}
